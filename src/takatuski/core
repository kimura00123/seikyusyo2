import os
from typing import Dict, Any, List
from datetime import datetime
from pathlib import Path
from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Border, Side, Alignment, NamedStyle
from openpyxl.utils import get_column_letter
from .structuring import DocumentStructure
from ..utils.logger import get_logger

logger = get_logger(__name__)


class ExcelExporter:
    """エクセル出力エンジン"""

    def __init__(self):
        # スタイル設定
        self.header_style = self._create_header_style()
        self.data_style = self._create_data_style()
        self.amount_style = self._create_amount_style()
        self.date_style = self._create_date_style()

    def export_to_excel(self, data: DocumentStructure, output_path: str) -> str:
        """
        構造化データをエクセルファイルに出力する

        Args:
            data (DocumentStructure): 出力対象のデータ
            output_path (str): 出力ファイルのパス

        Returns:
            str: 出力されたファイルのパス
        """
        try:
            # ワークブックの作成
            wb = Workbook()
            ws = wb.active
            ws.title = "請求書データ"

            # ヘッダーの設定
            headers = [
                # ドキュメント情報
                "PDF名",
                "合計金額",
                # 顧客情報
                "顧客コード",
                "顧客名",
                "部署",
                "文書箱番号",
                # 明細情報
                "明細番号",
                "摘要",
                "税率",
                "金額",
                "日付範囲",
                "ページ番号",
                # 在庫情報
                "繰越在庫",
                "入庫数",
                "W値",
                "出庫数",
                "在庫残高",
                "合計",
                "単価",
                # 数量情報
                "数量",
                "単価",
            ]
            for col, header in enumerate(headers, 1):
                cell = ws.cell(row=1, column=col, value=header)
                cell.style = self.header_style

            # データの書き込み
            row = 2
            for customer in data.customers:
                for entry in customer.entries:
                    # 基本情報
                    ws.cell(row=row, column=1, value=data.pdf_filename).style = (
                        self.data_style
                    )
                    ws.cell(row=row, column=2, value=data.total_amount).style = (
                        self.amount_style
                    )

                    # 顧客情報
                    ws.cell(row=row, column=3, value=customer.customer_code).style = (
                        self.data_style
                    )
                    ws.cell(row=row, column=4, value=customer.customer_name).style = (
                        self.data_style
                    )
                    ws.cell(row=row, column=5, value=customer.department).style = (
                        self.data_style
                    )
                    ws.cell(row=row, column=6, value=customer.box_number).style = (
                        self.data_style
                    )

                    # 明細情報
                    ws.cell(row=row, column=7, value=entry.no).style = self.data_style
                    ws.cell(row=row, column=8, value=entry.description).style = (
                        self.data_style
                    )
                    ws.cell(row=row, column=9, value=entry.tax_rate).style = (
                        self.data_style
                    )
                    ws.cell(row=row, column=10, value=entry.amount).style = (
                        self.amount_style
                    )
                    ws.cell(row=row, column=11, value=entry.date_range).style = (
                        self.date_style
                    )
                    ws.cell(row=row, column=12, value=entry.page_no).style = (
                        self.data_style
                    )

                    # 在庫情報
                    if entry.stock_info:
                        ws.cell(
                            row=row, column=13, value=entry.stock_info.carryover
                        ).style = self.data_style
                        ws.cell(
                            row=row, column=14, value=entry.stock_info.incoming
                        ).style = self.data_style
                        ws.cell(
                            row=row, column=15, value=entry.stock_info.w_value
                        ).style = self.data_style
                        ws.cell(
                            row=row, column=16, value=entry.stock_info.outgoing
                        ).style = self.data_style
                        ws.cell(
                            row=row, column=17, value=entry.stock_info.remaining
                        ).style = self.data_style
                        ws.cell(
                            row=row, column=18, value=entry.stock_info.total
                        ).style = self.data_style
                        ws.cell(
                            row=row, column=19, value=entry.stock_info.unit_price
                        ).style = self.amount_style

                    # 数量情報
                    if entry.quantity_info:
                        ws.cell(
                            row=row, column=20, value=entry.quantity_info.quantity
                        ).style = self.data_style
                        ws.cell(
                            row=row, column=21, value=entry.quantity_info.unit_price
                        ).style = self.amount_style

                    row += 1

            # 列幅の自動調整
            for col in range(1, len(headers) + 1):
                ws.column_dimensions[get_column_letter(col)].auto_size = True

            # ファイルの保存
            output_dir = os.path.dirname(output_path)
            os.makedirs(output_dir, exist_ok=True)
            wb.save(output_path)

            logger.info(f"エクセルファイルを出力: {output_path}")
            return output_path

        except Exception as e:
            logger.error(f"エクセル出力でエラー: {e}", exc_info=True)
            raise

    def _create_header_style(self) -> NamedStyle:
        """ヘッダー行のスタイルを作成する"""
        style = NamedStyle(name="header")
        style.font = Font(bold=True, size=11)
        style.fill = PatternFill(
            start_color="CCE5FF", end_color="CCE5FF", fill_type="solid"
        )
        style.border = Border(
            left=Side(style="thin"),
            right=Side(style="thin"),
            top=Side(style="thin"),
            bottom=Side(style="thin"),
        )
        style.alignment = Alignment(
            horizontal="center", vertical="center", wrap_text=True
        )
        return style

    def _create_data_style(self) -> NamedStyle:
        """データ行のスタイルを作成する"""
        style = NamedStyle(name="data")
        style.font = Font(size=10)
        style.border = Border(
            left=Side(style="thin"),
            right=Side(style="thin"),
            top=Side(style="thin"),
            bottom=Side(style="thin"),
        )
        style.alignment = Alignment(vertical="center")
        return style

    def _create_amount_style(self) -> NamedStyle:
        """金額のスタイルを作成する"""
        style = NamedStyle(name="amount")
        style.font = Font(size=10)
        style.border = Border(
            left=Side(style="thin"),
            right=Side(style="thin"),
            top=Side(style="thin"),
            bottom=Side(style="thin"),
        )
        style.alignment = Alignment(horizontal="right", vertical="center")
        style.number_format = "#,##0"
        return style

    def _create_date_style(self) -> NamedStyle:
        """日付のスタイルを作成する"""
        style = NamedStyle(name="date")
        style.font = Font(size=10)
        style.border = Border(
            left=Side(style="thin"),
            right=Side(style="thin"),
            top=Side(style="thin"),
            bottom=Side(style="thin"),
        )
        style.alignment = Alignment(horizontal="center", vertical="center")
        style.number_format = "yyyy/mm/dd"
        return style


